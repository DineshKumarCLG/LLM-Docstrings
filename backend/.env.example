# VeriDoc — Environment Variables
# Copy this file to .env and fill in your API keys.
# All keys are prefixed with VERIDOC_ (see config.py)

# ============================================================
# LLM API Keys (set at least ONE)
# ============================================================

# OpenAI — model: gpt-4.1-mini
VERIDOC_OPENAI_API_KEY=

# Anthropic — model: claude-sonnet-4-20250514
VERIDOC_ANTHROPIC_API_KEY=

# Google Gemini — model: gemini-3-flash-preview (recommended for quick start)
VERIDOC_GOOGLE_API_KEY=

# ============================================================
# AWS Bedrock (optional)
# ============================================================
VERIDOC_AWS_ACCESS_KEY_ID=
VERIDOC_AWS_SECRET_ACCESS_KEY=
VERIDOC_AWS_REGION=us-east-1
VERIDOC_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ============================================================
# Infrastructure
# ============================================================
VERIDOC_DATABASE_URL=sqlite:///./veridoc.db
VERIDOC_REDIS_URL=redis://localhost:6379/0
VERIDOC_FRONTEND_ORIGIN=http://localhost:5173
